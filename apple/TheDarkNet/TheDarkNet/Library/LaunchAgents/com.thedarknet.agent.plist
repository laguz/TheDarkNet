<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.thedarknet.agent</string>
    <key>ProgramArguments</key>
    <array>
        <string>__TDN_AGENT_PATH__</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>
    <key>ProcessType</key>
    <string>Interactive</string>
    <key>LimitLoadToSessionType</key>
    <string>Aqua</string>
    <key>StandardErrorPath</key>
    <string>__TDN_LOG_DIR__/agent.err.log</string>
    <key>StandardOutPath</key>
    <string>__TDN_LOG_DIR__/agent.out.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>TDN_HOME</key>
        <string>__TDN_HOME__</string>
    </dict>
</dict>
</plist>
